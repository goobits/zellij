// Keep Zellij close to its defaults, with Mac-friendly prefix shortcuts.
default_mode "normal"
default_layout "default"
default_shell "/usr/bin/zsh"
pane_frames false
auto_layout true
session_serialization true
serialize_pane_viewport true
serialization_interval 10
post_command_discovery_hook "printf '%s\n' /usr/bin/zsh"
scroll_buffer_size 50000
scrollback_editor "/usr/bin/vim"
simplified_ui false
mouse_mode true
advanced_mouse_actions false
mouse_click_through true
mouse_hover_effects false
focus_follows_mouse true
copy_on_select false
osc8_hyperlinks true
show_release_notes false

keybinds {
    normal {
        bind "Super c" { Copy; }
        bind "Alt c" { Copy; }
        bind "Ctrl y" { Copy; }
        bind "PageUp" { PageScrollUp; SwitchToMode "Scroll"; }
        bind "PageDown" { PageScrollDown; }
    }
    scroll {
        bind "Super c" { Copy; }
        bind "Alt c" { Copy; }
        bind "Ctrl y" { Copy; }
    }
    shared_except "locked" {
        unbind "Alt f" "Alt n" "Alt i" "Alt o"
        unbind "Alt h" "Alt Left" "Alt l" "Alt Right"
        unbind "Alt j" "Alt Down" "Alt k" "Alt Up"
        unbind "Alt =" "Alt +" "Alt -" "Alt [" "Alt ]"
        unbind "Alt p" "Alt Shift p"
    }
}
