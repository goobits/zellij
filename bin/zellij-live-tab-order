#!/usr/bin/env bash
set -euo pipefail

session="${1:-}"
shift || true

if [[ -z "$session" || "$#" -eq 0 ]]; then
  printf 'usage: zellij-live-tab-order <session> <tab-name>[<tab><cwd>]...\n' >&2
  exit 2
fi

if [[ ! "$session" =~ ^[A-Za-z0-9_.-]+$ ]]; then
  printf 'zellij-live-tab-order: session names may only use letters, numbers, dot, underscore, and dash\n' >&2
  exit 2
fi

if ! zellij list-sessions --short --no-formatting 2>/dev/null | grep -Fx "$session" >/dev/null; then
  exit 0
fi

if ! command -v jq >/dev/null 2>&1; then
  exit 0
fi

list_tabs() {
  ZELLIJ_SESSION_NAME="$session" zellij action list-tabs --json 2>/dev/null || true
}

close_status_bar_panes() {
  local desired_json pane_state pane_id

  desired_json="$(
    printf '%s\n' "${desired_tabs[@]}" | jq -R . | jq -s .
  )"
  pane_state="$(ZELLIJ_SESSION_NAME="$session" zellij action list-panes --all --json 2>/dev/null || true)"
  [[ -n "$pane_state" ]] || return 0

  while IFS= read -r pane_id; do
    [[ -z "$pane_id" ]] && continue
    ZELLIJ_SESSION_NAME="$session" zellij action close-pane --pane-id "plugin_${pane_id}" >/dev/null 2>&1 || true
  done < <(
    jq -r --argjson desired "$desired_json" '
      def base_name:
        sub(" 🤖$"; "")
        | sub(" 🔔$"; "");

      .[]
      | select(.is_plugin == true)
      | select((.title // "") == "zellij:status-bar")
      | select([(.tab_name | base_name)] | inside($desired))
      | .id
    ' <<<"$pane_state" 2>/dev/null || true
  )
}

desired_tabs=()
desired_cwds=()
for tab_spec in "$@"; do
  tab_name="${tab_spec%%$'\t'*}"
  tab_cwd="${ZELLIJ_SESSION_TAB_DEFAULT_CWD:-${PWD:-/workspace}}"
  if [[ "$tab_spec" == *$'\t'* ]]; then
    tab_cwd="${tab_spec#*$'\t'}"
  fi
  [[ -n "$tab_name" ]] || continue
  desired_tabs+=("$tab_name")
  desired_cwds+=("$tab_cwd")
done

tab_query='
  def base_name:
    sub(" 🤖$"; "")
    | sub(" 🔔$"; "");

  .[]
  | select((.name | base_name) == $name)
  | [.tab_id, .position]
  | @tsv
'

tab_state="$(list_tabs)"
[[ -n "$tab_state" ]] || exit 0

active_tab_id="$(
  jq -r '.[] | select(.active == true) | .tab_id' <<<"$tab_state" 2>/dev/null | head -n 1
)"

if [[ "${ZELLIJ_SESSION_TAB_ORDER_CREATE_MISSING:-0}" == "1" ]]; then
  for tab_index in "${!desired_tabs[@]}"; do
    tab_name="${desired_tabs[$tab_index]}"
    row="$(jq -r --arg name "$tab_name" "$tab_query" <<<"$tab_state" 2>/dev/null | head -n 1)"
    if [[ -n "$row" ]]; then
      continue
    fi

    ZELLIJ_SESSION_NAME="$session" zellij action new-tab --name "$tab_name" --cwd "${desired_cwds[$tab_index]}" >/dev/null 2>&1 || true
    tab_state="$(list_tabs)"
    [[ -n "$tab_state" ]] || exit 0
  done
fi

close_status_bar_panes

target_position=0
for tab_name in "${desired_tabs[@]}"; do
  tab_state="$(list_tabs)"
  [[ -n "$tab_state" ]] || continue

  row="$(jq -r --arg name "$tab_name" "$tab_query" <<<"$tab_state" 2>/dev/null | head -n 1)"
  [[ -n "$row" ]] || continue

  IFS=$'\t' read -r tab_id current_position <<<"$row"
  if [[ ! "$current_position" =~ ^[0-9]+$ ]]; then
    continue
  fi

  if (( current_position > target_position )); then
    ZELLIJ_SESSION_NAME="$session" zellij action go-to-tab-by-id "$tab_id" >/dev/null 2>&1 || true
    for (( index = current_position; index > target_position; index-- )); do
      ZELLIJ_SESSION_NAME="$session" zellij action move-tab left >/dev/null 2>&1 || true
    done
  fi

  target_position=$((target_position + 1))
done

if [[ -n "${active_tab_id:-}" ]]; then
  ZELLIJ_SESSION_NAME="$session" zellij action go-to-tab-by-id "$active_tab_id" >/dev/null 2>&1 || true
fi

ZELLIJ_SESSION_NAME="$session" zellij action save-session >/dev/null 2>&1 || true
