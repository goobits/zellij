#!/usr/bin/env bash
set -euo pipefail

command_name="${1:-}"
script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  local stream="${1:-stderr}"
  if [[ "$stream" == "stdout" ]]; then
    cat
  else
    cat >&2
  fi <<'EOF'
goob: Zero-friction Zellij workspaces

usage:
  goob                                open the default workspace
  goob <workspace> [-s <session>] [-r <root>]

workspaces:
  goob list [--config <profile-dir>]
  goob create <workspace> <tabs...>
  goob refresh <workspace>
  goob rename <workspace> <new-workspace>
  goob remove <workspace>
  goob <workspace>=<tab>,...          create, add, replace, and sync a workspace

tabs:
  goob tab list <workspace>
  goob tab add <workspace> <tab[@index]>
  goob tab move <workspace> <tab@index>
  goob tab rename <workspace> <old-tab> <new-tab>
  goob tab remove <workspace> <tab>

sessions:
  goob ps
  goob kill <session>

commit queue:
  goob commit setup [workspace] [--tab Git] [--agent codex|--no-agent]
  goob commit add <title> <path>... [--check <cmd>] [--poke [tab]]
  goob commit status
  goob commit poke [tab]

commit queue plumbing:
  goob commit request --title <title> --path <path>... [--verify <cmd>] [--poke [tab]]
  goob commit next
  goob commit done <id-or-file>
  goob commit block <id-or-file> --reason <reason>
  goob commit check
  goob commit list

system:
  goob install
  goob setup --config <profile-dir>
  goob doctor [--config <profile-dir>]
  goob help

legacy tab aliases still work:
  goob <workspace> list|add|move|rename|remove|refresh ...
EOF
}

validate_name() {
  local kind="$1" value="$2"
  if [[ ! "$value" =~ ^[A-Za-z0-9_.-]+$ ]]; then
    printf 'goob: %s may only use letters, numbers, dot, underscore, and dash: %s\n' "$kind" "$value" >&2
    exit 2
  fi
}

profile_value() {
  local config_file="$1" key="$2" default_value="${3:-}"
  if [[ ! -f "$config_file" ]]; then
    printf '%s' "$default_value"
    return
  fi

  awk -F '=' -v key="$key" -v default_value="$default_value" '
    $1 == key {
      value = substr($0, length(key) + 2)
      gsub(/\r$/, "", value)
      print value
      found = 1
      exit
    }
    END {
      if (!found) print default_value
    }
  ' "$config_file"
}

find_config_dir() {
  local candidate

  if [[ -n "${GOOB_CONFIG_DIR:-}" ]]; then
    candidate="$GOOB_CONFIG_DIR"
    if [[ -f "$candidate/profile.conf" ]]; then
      cd "$candidate"
      pwd
      return
    fi
  fi

  candidate="$PWD/config/zellij"
  if [[ -f "$candidate/profile.conf" ]]; then
    cd "$candidate"
    pwd
    return
  fi

  return 1
}

resolve_profile_name() {
  local config_dir="${1:-}" default_file="$HOME/.local/share/zellij-workspaces/default-profile"

  if [[ -n "$config_dir" && -f "$config_dir/profile.conf" ]]; then
    profile_value "$config_dir/profile.conf" name "$(basename "$config_dir")"
    return
  fi

  if [[ -f "$default_file" ]]; then
    sed -n '1p' "$default_file"
    return
  fi

  printf 'zellij'
}

resolve_config_arg() {
  local config_dir=""
  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --config)
        config_dir="${2:-}"
        shift 2
        ;;
      *)
        printf 'goob: unknown argument %s\n' "$1" >&2
        usage
        exit 2
        ;;
    esac
  done

  if [[ -z "$config_dir" ]]; then
    if config_dir="$(find_config_dir)"; then
      :
    else
      printf 'goob: could not find config/zellij; pass --config <profile-dir>\n' >&2
      exit 1
    fi
  fi

  if [[ ! -f "$config_dir/profile.conf" ]]; then
    printf 'goob: missing %s/profile.conf\n' "$config_dir" >&2
    exit 1
  fi

  cd "$config_dir"
  pwd
}

install_profile() {
  local config_dir="$1"
  "$script_dir/zellij-workspace-init" --config "$config_dir" >/dev/null
}

auto_install_config() {
  local config_dir="${1:-}"
  if [[ -z "$config_dir" ]]; then
    if ! config_dir="$(find_config_dir)"; then
      return 1
    fi
  fi

  install_profile "$config_dir"
  printf '%s' "$config_dir"
}

profile_dir_from_installed_default() {
  local profile_name
  profile_name="$(resolve_profile_name "")"
  printf '%s/.local/share/zellij-workspaces/profiles/%s' "$HOME" "$profile_name"
}

default_workspace_from_config() {
  local config_dir="$1" default_workspace

  default_workspace="$(profile_value "$config_dir/profile.conf" default_workspace "")"
  if [[ -n "$default_workspace" ]]; then
    printf '%s' "$default_workspace"
    return
  fi

  default_workspace="$(profile_value "$config_dir/profile.conf" default_workspaces "")"
  printf '%s' "${default_workspace%% *}"
}

list_workspaces() {
  local config_dir="$1" tabs_files=()
  shopt -s nullglob
  tabs_files=("$config_dir"/*.tabs)
  shopt -u nullglob

  for tabs_file in "${tabs_files[@]:-}"; do
    basename "$tabs_file" .tabs
  done
}

workspace_exists_or_exit() {
  local profile_dir="$1" workspace="$2" available local_tabs

  if [[ -f "$profile_dir/$workspace.tabs" ]]; then
    return
  fi

  printf 'goob: workspace not found: %s\n' "$workspace" >&2
  printf 'Looked in: %s\n' "$profile_dir" >&2
  available="$(list_workspaces "$profile_dir")"
  if [[ -n "$available" ]]; then
    printf 'Available workspaces:\n%s\n' "$available" >&2
  else
    printf 'No workspaces are installed for this profile.\n' >&2
  fi
  local_tabs="$PWD/config/zellij/$workspace.tabs"
  if [[ -f "$local_tabs" ]]; then
    printf 'A local workspace file exists. Refresh with: goob setup --config config/zellij\n' >&2
  else
    printf 'Create it with: goob %s=<tab>,...\n' "$workspace" >&2
  fi
  exit 1
}

resolve_root() {
  local root_arg="$1"
  if [[ ! -d "$root_arg" ]]; then
    printf 'goob: root directory does not exist: %s\n' "$root_arg" >&2
    exit 1
  fi
  cd "$root_arg"
  pwd
}

write_tabs_file() {
  local config_dir="$1" workspace="$2"
  shift 2

  validate_name workspace "$workspace"
  if [[ "$#" -eq 0 ]]; then
    printf 'goob: workspace %s must have at least one tab\n' "$workspace" >&2
    exit 2
  fi

  : > "$config_dir/$workspace.tabs"
  for tab in "$@"; do
    validate_name tab "$tab"
    printf '%s\n' "$tab" >> "$config_dir/$workspace.tabs"
  done
}

add_profile_workspace() {
  local config_file="$1" workspace="$2" tmp default_workspaces current seen=false

  default_workspaces="$(profile_value "$config_file" default_workspaces "")"
  for current in $default_workspaces; do
    if [[ "$current" == "$workspace" ]]; then
      seen=true
      break
    fi
  done

  if [[ "$seen" == "true" ]]; then
    return
  fi

  if [[ -n "$default_workspaces" ]]; then
    default_workspaces="$default_workspaces $workspace"
  else
    default_workspaces="$workspace"
  fi

  tmp="$(mktemp)"
  awk -F '=' -v default_workspaces="$default_workspaces" '
    $1 == "default_workspaces" {
      print "default_workspaces=" default_workspaces
      updated = 1
      next
    }
    { print }
    END {
      if (!updated) print "default_workspaces=" default_workspaces
    }
  ' "$config_file" > "$tmp"
  cat "$tmp" > "$config_file"
  rm -f "$tmp"
}

parse_tabs_csv() {
  local csv="$1" tab
  IFS=',' read -r -a parsed_tabs <<<"$csv"
  if (( ${#parsed_tabs[@]} == 0 )); then
    printf 'goob: expected at least one tab\n' >&2
    exit 2
  fi
  for tab in "${parsed_tabs[@]}"; do
    if [[ -z "$tab" ]]; then
      printf 'goob: empty tab name in %s\n' "$csv" >&2
      exit 2
    fi
    validate_name tab "$tab"
  done
}

parse_tabs_args() {
  local tab
  parsed_tabs=()

  if (( "$#" == 1 )) && [[ "${1:-}" == *","* ]]; then
    parse_tabs_csv "$1"
    return
  fi

  if (( "$#" == 0 )); then
    printf 'goob: expected at least one tab\n' >&2
    exit 2
  fi

  for tab in "$@"; do
    if [[ -z "$tab" ]]; then
      printf 'goob: empty tab name\n' >&2
      exit 2
    fi
    validate_name tab "$tab"
    parsed_tabs+=("$tab")
  done
}

sync_workspace_session() {
  local config_dir="$1" workspace="$2" tab_order_helper="$script_dir/zellij-session-tab-order"
  local tab_order=() default_cwd

  [[ -x "$tab_order_helper" ]] || return 0
  mapfile -t tab_order < "$config_dir/$workspace.tabs"
  [[ "${#tab_order[@]}" -gt 0 ]] || return 0

  default_cwd="$(profile_value "$config_dir/profile.conf" root "${PWD:-/workspace}")"
  ZELLIJ_SESSION_TAB_DEFAULT_CWD="$default_cwd" \
  ZELLIJ_SESSION_TAB_ORDER_CREATE_MISSING=1 \
    "$tab_order_helper" "$workspace" "${tab_order[@]}"
}

tab_name_from_line() {
  local line="$1"
  printf '%s' "${line%%$'\t'*}"
}

indexed_tab_spec() {
  local spec="$1"
  tab_name="$spec"
  tab_index=""

  if [[ "$spec" =~ ^(.+)@([0-9]+)$ ]]; then
    tab_name="${BASH_REMATCH[1]}"
    tab_index="${BASH_REMATCH[2]}"
  fi

  validate_name tab "$tab_name"
}

write_tab_lines() {
  local target_file="$1"
  shift

  : > "$target_file"
  for line in "$@"; do
    printf '%s\n' "$line" >> "$target_file"
  done
}

upsert_workspace_tab_line() {
  local tabs_file="$1" spec="$2" existing_line="" line current_name insert_index
  local current_lines=() next_lines=()

  indexed_tab_spec "$spec"
  insert_index="$tab_index"
  mapfile -t current_lines < "$tabs_file"

  for line in "${current_lines[@]}"; do
    current_name="$(tab_name_from_line "$line")"
    if [[ "$current_name" == "$tab_name" ]]; then
      existing_line="$line"
      continue
    fi
    next_lines+=("$line")
  done

  line="${existing_line:-$tab_name}"
  if [[ -z "$insert_index" || "$insert_index" -ge "${#next_lines[@]}" ]]; then
    next_lines+=("$line")
  else
    next_lines=("${next_lines[@]:0:$insert_index}" "$line" "${next_lines[@]:$insert_index}")
  fi

  write_tab_lines "$tabs_file" "${next_lines[@]}"
}

remove_workspace_tab_line() {
  local tabs_file="$1" remove_name="$2" line current_name found=false
  local current_lines=() next_lines=()

  validate_name tab "$remove_name"
  mapfile -t current_lines < "$tabs_file"

  for line in "${current_lines[@]}"; do
    current_name="$(tab_name_from_line "$line")"
    if [[ "$current_name" == "$remove_name" ]]; then
      found=true
      continue
    fi
    next_lines+=("$line")
  done

  if [[ "$found" != "true" ]]; then
    printf 'goob: tab not found in workspace file: %s\n' "$remove_name" >&2
    exit 1
  fi

  write_tab_lines "$tabs_file" "${next_lines[@]}"
}

rename_workspace_tab_line() {
  local tabs_file="$1" old_name="$2" new_name="$3" line current_name rest found=false
  local current_lines=() next_lines=()

  validate_name tab "$old_name"
  validate_name tab "$new_name"
  mapfile -t current_lines < "$tabs_file"

  for line in "${current_lines[@]}"; do
    current_name="$(tab_name_from_line "$line")"
    if [[ "$current_name" == "$new_name" ]]; then
      printf 'goob: tab already exists in workspace file: %s\n' "$new_name" >&2
      exit 1
    fi
  done

  for line in "${current_lines[@]}"; do
    current_name="$(tab_name_from_line "$line")"
    if [[ "$current_name" == "$old_name" ]]; then
      found=true
      rest="${line#"$current_name"}"
      next_lines+=("$new_name$rest")
      continue
    fi
    next_lines+=("$line")
  done

  if [[ "$found" != "true" ]]; then
    printf 'goob: tab not found in workspace file: %s\n' "$old_name" >&2
    exit 1
  fi

  write_tab_lines "$tabs_file" "${next_lines[@]}"
}

live_tab_rows() {
  local session="$1" match_name="${2:-}"

  command -v jq >/dev/null 2>&1 || return 0
  ZELLIJ_SESSION_NAME="$session" zellij action list-tabs --json 2>/dev/null | jq -r --arg name "$match_name" '
    def base_name:
      sub(" 🤖$"; "")
      | sub(" 🔔$"; "");

    .[]
    | {
        id: .tab_id,
        position: .position,
        active: .active,
        name: .name,
        base: (.name | base_name)
      }
    | select($name == "" or .base == $name)
    | [.id, .position, .active, .base, .name]
    | @tsv
  ' 2>/dev/null || true
}

close_live_tab_if_present() {
  local session="$1" requested_name="$2" rows=() row tab_id

  mapfile -t rows < <(live_tab_rows "$session" "$requested_name")
  (( ${#rows[@]} > 0 )) || return 0

  if (( ${#rows[@]} > 1 )); then
    printf 'goob: tab name is ambiguous in session %s: %s\n' "$session" "$requested_name" >&2
    printf '%s\n' "${rows[@]}" >&2
    exit 1
  fi

  row="${rows[0]}"
  tab_id="${row%%$'\t'*}"
  ZELLIJ_SESSION_NAME="$session" zellij action close-tab-by-id "$tab_id" >/dev/null 2>&1 || true
  ZELLIJ_SESSION_NAME="$session" zellij action save-session >/dev/null 2>&1 || true
}

list_workspace_tabs() {
  local workspace="$1" tabs_file="$2" rows=() row current_name marker live_count=0

  mapfile -t rows < <(live_tab_rows "$workspace")
  live_count="${#rows[@]}"

  if (( live_count > 0 )); then
    for row in "${rows[@]}"; do
      IFS=$'\t' read -r _tab_id position active current_name _display_name <<<"$row"
      marker=" "
      [[ "$active" == "true" ]] && marker="*"
      printf '%s %s %s\n' "$marker" "$position" "$current_name"
    done
    return
  fi

  awk -F '\t' '{ printf "  %d %s\n", NR - 1, $1 }' "$tabs_file"
}

refresh_workspace_tabs() {
  local workspace="$1" tabs_file="$2" rows=() expected_lines=() row tab_id position active current_name display_name expected_name renamed=0

  mapfile -t rows < <(live_tab_rows "$workspace")
  if (( ${#rows[@]} == 0 )); then
    printf 'goob: no live tabs found for session %s\n' "$workspace" >&2
    return 1
  fi

  mapfile -t expected_lines < "$tabs_file"
  for row in "${rows[@]}"; do
    IFS=$'\t' read -r tab_id position active current_name display_name <<<"$row"
    if [[ ! "$position" =~ ^[0-9]+$ || "$position" -ge "${#expected_lines[@]}" ]]; then
      continue
    fi

    expected_name="$(tab_name_from_line "${expected_lines[$position]}")"
    if [[ -n "$expected_name" && "$current_name" != "$expected_name" ]]; then
      ZELLIJ_SESSION_NAME="$workspace" zellij action rename-tab-by-id "$tab_id" "$expected_name" >/dev/null
      renamed=$((renamed + 1))
    fi
  done

  ZELLIJ_SESSION_NAME="$workspace" zellij action save-session >/dev/null 2>&1 || true
  printf 'Refreshed %s tab titles (%s renamed).\n' "$workspace" "$renamed"
}

commit_queue_helper() {
  local dir="$PWD"

  if [[ -n "${GOOB_COMMIT_QUEUE_HELPER:-}" ]]; then
    if [[ -f "$GOOB_COMMIT_QUEUE_HELPER" ]]; then
      printf '%s' "$GOOB_COMMIT_QUEUE_HELPER"
      return
    fi
    printf 'goob: missing GOOB_COMMIT_QUEUE_HELPER: %s\n' "$GOOB_COMMIT_QUEUE_HELPER" >&2
    exit 1
  fi

  while [[ "$dir" != "/" ]]; do
    if [[ -f "$dir/tasks/workspace/commitq.mjs" ]]; then
      printf '%s/tasks/workspace/commitq.mjs' "$dir"
      return
    fi
    dir="$(dirname "$dir")"
  done

  printf 'goob: could not find tasks/workspace/commitq.mjs from %s\n' "$PWD" >&2
  exit 1
}

run_commit_queue() {
  local helper
  helper="$(commit_queue_helper)"
  node "$helper" "$@"
}

print_commit_status() {
  local pending done blocked unsafe next_tmp check_tmp

  pending="$(run_commit_queue list "$@" 2>/dev/null | wc -l | tr -d ' ')"
  done="$(run_commit_queue list --state done "$@" 2>/dev/null | wc -l | tr -d ' ')"
  blocked="$(run_commit_queue list --state blocked "$@" 2>/dev/null | wc -l | tr -d ' ')"
  check_tmp="$(mktemp)"
  if run_commit_queue check --json "$@" >"$check_tmp" 2>/dev/null; then
    :
  fi
  unsafe="$(node -e "const fs=require('fs'); const p=process.argv[1]; let n=0; try { n=(JSON.parse(fs.readFileSync(p,'utf8')).blockers||[]).length } catch {} console.log(n)" "$check_tmp")"

  printf 'Pending  %s\n' "$pending"
  printf 'Unsafe   %s\n' "$unsafe"
  printf 'Blocked  %s\n' "$blocked"
  printf 'Done     %s\n' "$done"

  next_tmp="$(mktemp)"
  if [[ "$unsafe" == "0" ]] && run_commit_queue next "$@" >"$next_tmp" 2>/dev/null; then
    if [[ -s "$next_tmp" ]] && ! grep -Fxq 'No safe pending commit request.' "$next_tmp"; then
      printf 'Next     %s\n' "$(sed -n '1p' "$next_tmp")"
    fi
  fi
  if [[ "$unsafe" != "0" ]]; then
    printf 'Next     blocked; run `goob commit check`\n'
  fi
  rm -f "$next_tmp" "$check_tmp"
}

commit_tab_id() {
  local requested_name="$1" session="${2:-}"

  command -v jq >/dev/null 2>&1 || return 0
  if [[ -n "$session" ]]; then
    ZELLIJ_SESSION_NAME="$session" zellij action list-tabs --json 2>/dev/null
  else
    zellij action list-tabs --json 2>/dev/null
  fi | jq -r --arg name "$requested_name" '
    def base_name:
      sub(" 🤖$"; "")
      | sub(" 🔔$"; "");

    .[]
    | select((.name | base_name) == $name)
    | .tab_id
  ' 2>/dev/null | sed -n '1p'
}

send_to_commit_tab() {
  local requested_name="${1:-Git}" message="${2:-}" session="${3:-}" missing_message="${4:-}" tab_id

  validate_name tab "$requested_name"
  tab_id="$(commit_tab_id "$requested_name" "$session")"
  if [[ -z "$tab_id" ]]; then
    if [[ -n "$missing_message" ]]; then
      printf '%s\n' "$missing_message"
    else
      printf 'No live Zellij tab named %s was found to poke.\n' "$requested_name"
    fi
    return 1
  fi

  if [[ -n "$session" ]]; then
    ZELLIJ_SESSION_NAME="$session" zellij action go-to-tab-by-id "$tab_id" >/dev/null
    ZELLIJ_SESSION_NAME="$session" zellij action write-chars "$message" >/dev/null
    ZELLIJ_SESSION_NAME="$session" zellij action send-keys Enter >/dev/null
  else
    zellij action go-to-tab-by-id "$tab_id" >/dev/null
    zellij action write-chars "$message" >/dev/null
    zellij action send-keys Enter >/dev/null
  fi
}

poke_commit_tab() {
  local requested_name="${1:-Git}" session="${2:-}" missing_message="${3:-}"

  if send_to_commit_tab "$requested_name" '$x-commit next' "$session" "$missing_message"; then
    printf 'Poked %s with $x-commit next.\n' "$requested_name"
  fi
}

setup_commit_tab() {
  local workspace="${1:-}" tab_name="Git" agent_command="codex" config_dir tabs_file default_workspace

  if [[ -n "$workspace" && "$workspace" == --* ]]; then
    workspace=""
  fi
  if [[ -n "$workspace" ]]; then
    shift
  fi

  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --tab)
        if [[ -z "${2:-}" ]]; then
          printf 'goob: --tab requires a value\n' >&2
          exit 2
        fi
        tab_name="${2:-}"
        shift 2
        ;;
      --agent)
        if [[ -z "${2:-}" ]]; then
          printf 'goob: --agent requires a value\n' >&2
          exit 2
        fi
        agent_command="${2:-}"
        shift 2
        ;;
      --no-agent)
        agent_command=""
        shift
        ;;
      *)
        printf 'goob: unknown commit setup argument %s\n' "$1" >&2
        usage
        exit 2
        ;;
    esac
  done

  validate_name tab "$tab_name"
  if config_dir="$(find_config_dir)"; then
    :
  else
    printf 'goob: could not find config/zellij; create a workspace first\n' >&2
    exit 1
  fi

  if [[ -z "$workspace" ]]; then
    default_workspace="$(default_workspace_from_config "$config_dir")"
    workspace="$default_workspace"
  fi
  if [[ -z "$workspace" ]]; then
    printf 'goob: no default workspace configured; pass a workspace name\n' >&2
    exit 1
  fi
  validate_name workspace "$workspace"

  tabs_file="$config_dir/$workspace.tabs"
  if [[ ! -f "$tabs_file" ]]; then
    printf 'goob: missing workspace %s in %s\n' "$workspace" "$config_dir" >&2
    exit 1
  fi

  upsert_workspace_tab_line "$tabs_file" "$tab_name"
  install_profile "$config_dir" >/dev/null
  sync_workspace_session "$config_dir" "$workspace"

  if [[ -n "$agent_command" ]]; then
    if send_to_commit_tab "$tab_name" "$agent_command" "$workspace" >/dev/null; then
      printf 'Commit tab %s is ready in %s and received `%s`.\n' "$tab_name" "$workspace" "$agent_command"
      return 0
    fi
  fi

  printf 'Commit tab %s is ready in %s.\n' "$tab_name" "$workspace"
}

run_commit_command() {
  local action="${1:-}" poke=false poke_tab="Git" filtered=() arg path_count=0

  if [[ -z "$action" ]]; then
    printf 'goob: commit requires an action\n' >&2
    usage
    exit 2
  fi
  shift

  case "$action" in
    setup)
      setup_commit_tab "$@"
      ;;
    add)
      if [[ "$#" -lt 2 ]]; then
        printf 'goob: commit add requires a title and at least one path\n' >&2
        usage
        exit 2
      fi
      filtered=(--title "$1")
      path_count=0
      shift
      while [[ "$#" -gt 0 ]]; do
        arg="$1"
        case "$arg" in
          --check | --verify)
            if [[ -z "${2:-}" ]]; then
              printf 'goob: %s requires a value\n' "$arg" >&2
              exit 2
            fi
            filtered+=(--verify "${2:-}")
            shift 2
            ;;
          --root | --summary | --owner | --must-contain | --must-not-contain)
            if [[ -z "${2:-}" ]]; then
              printf 'goob: %s requires a value\n' "$arg" >&2
              exit 2
            fi
            filtered+=("$arg" "${2:-}")
            shift 2
            ;;
          --poke)
            poke=true
            shift
            if [[ "${1:-}" != "" && "${1:-}" != --* ]]; then
              poke_tab="$1"
              shift
            fi
            ;;
          --*)
            printf 'goob: unknown commit add argument %s\n' "$arg" >&2
            usage
            exit 2
            ;;
          *)
            filtered+=(--path "$arg")
            path_count=$((path_count + 1))
            shift
            ;;
        esac
      done
      if [[ "$path_count" -eq 0 ]]; then
        printf 'goob: commit add requires at least one path\n' >&2
        usage
        exit 2
      fi
      run_commit_queue request "${filtered[@]}"
      if [[ "$poke" == "true" ]]; then
        poke_commit_tab "$poke_tab" "" "Created commit request. No live Zellij tab named $poke_tab was found to poke."
      fi
      ;;
    request)
      while [[ "$#" -gt 0 ]]; do
        arg="$1"
        case "$arg" in
          --check)
            if [[ -z "${2:-}" ]]; then
              printf 'goob: %s requires a value\n' "$arg" >&2
              exit 2
            fi
            filtered+=(--verify "${2:-}")
            shift 2
            ;;
          --poke)
            poke=true
            shift
            if [[ "${1:-}" != "" && "${1:-}" != --* ]]; then
              poke_tab="$1"
              shift
            fi
            ;;
          *)
            filtered+=("$arg")
            shift
            ;;
        esac
      done
      run_commit_queue request "${filtered[@]}"
      if [[ "$poke" == "true" ]]; then
        poke_commit_tab "$poke_tab"
      fi
      ;;
    status)
      print_commit_status "$@"
      ;;
    list | check | next | done | block)
      run_commit_queue "$action" "$@"
      ;;
    poke)
      if [[ "$#" -gt 1 ]]; then
        printf 'goob: commit poke accepts at most one tab name\n' >&2
        usage
        exit 2
      fi
      poke_commit_tab "${1:-Git}"
      ;;
    *)
      printf 'goob: unknown commit action %s\n' "$action" >&2
      usage
      exit 2
      ;;
  esac
}

run_workspace_tab_command() {
  local workspace="$1" action="$2" arg="${3:-}" extra="${4:-}" config_dir tabs_file

  validate_name workspace "$workspace"
  if ! config_dir="$(find_config_dir)"; then
    printf 'goob: could not find config/zellij; create a workspace first\n' >&2
    exit 1
  fi

  tabs_file="$config_dir/$workspace.tabs"
  if [[ ! -f "$tabs_file" ]]; then
    printf 'goob: missing workspace %s in %s\n' "$workspace" "$config_dir" >&2
    exit 1
  fi

  case "$action" in
    list)
      if [[ -n "$arg" || "$#" -ne 2 ]]; then
        printf 'goob: %s list does not accept extra arguments\n' "$workspace" >&2
        usage
        exit 2
      fi
      list_workspace_tabs "$workspace" "$tabs_file"
      ;;
    refresh)
      if [[ -n "$arg" || "$#" -ne 2 ]]; then
        printf 'goob: %s refresh does not accept extra arguments\n' "$workspace" >&2
        usage
        exit 2
      fi
      refresh_workspace_tabs "$workspace" "$tabs_file"
      ;;
    add)
      if [[ -z "$arg" || "$#" -ne 3 ]]; then
        printf 'goob: %s add requires exactly one tab name\n' "$workspace" >&2
        usage
        exit 2
      fi
      upsert_workspace_tab_line "$tabs_file" "$arg"
      install_profile "$config_dir" >/dev/null
      sync_workspace_session "$config_dir" "$workspace"
      printf 'Added tab %s to %s.\n' "$tab_name" "$workspace"
      ;;
    remove)
      if [[ -z "$arg" || "$#" -ne 3 ]]; then
        printf 'goob: %s remove requires exactly one tab name\n' "$workspace" >&2
        usage
        exit 2
      fi
      remove_workspace_tab_line "$tabs_file" "$arg"
      install_profile "$config_dir" >/dev/null
      close_live_tab_if_present "$workspace" "$arg"
      printf 'Removed tab %s from %s.\n' "$arg" "$workspace"
      ;;
    move)
      if [[ -z "$arg" || "$#" -ne 3 ]]; then
        printf 'goob: %s move requires exactly one tab@index spec\n' "$workspace" >&2
        usage
        exit 2
      fi
      indexed_tab_spec "$arg"
      if [[ -z "$tab_index" ]]; then
        printf 'goob: move requires an index, for example %s move %s@1\n' "$workspace" "$tab_name" >&2
        exit 2
      fi
      upsert_workspace_tab_line "$tabs_file" "$arg"
      install_profile "$config_dir" >/dev/null
      sync_workspace_session "$config_dir" "$workspace"
      printf 'Moved tab %s to %s@%s.\n' "$tab_name" "$workspace" "$tab_index"
      ;;
    rename)
      if [[ -z "$arg" || -z "$extra" || "$#" -ne 4 ]]; then
        printf 'goob: %s rename requires old and new tab names\n' "$workspace" >&2
        usage
        exit 2
      fi
      rename_workspace_tab_line "$tabs_file" "$arg" "$extra"
      install_profile "$config_dir" >/dev/null
      sync_workspace_session "$config_dir" "$workspace"
      refresh_workspace_tabs "$workspace" "$tabs_file" >/dev/null || true
      printf 'Renamed tab %s to %s in %s.\n' "$arg" "$extra" "$workspace"
      ;;
    *)
      printf 'goob: unknown workspace tab action %s\n' "$action" >&2
      usage
      exit 2
      ;;
  esac
}

upsert_local_workspace() {
  local spec="$1" workspace tabs_csv config_dir profile_name root created=false

  workspace="${spec%%=*}"
  tabs_csv="${spec#*=}"
  if [[ -z "$workspace" || -z "$tabs_csv" || "$workspace" == "$spec" ]]; then
    printf 'goob: expected workspace=tab,tab, got %s\n' "$spec" >&2
    exit 2
  fi

  validate_name workspace "$workspace"
  parse_tabs_csv "$tabs_csv"
  if ! config_dir="$(find_config_dir)"; then
    config_dir="${GOOB_CONFIG_DIR:-$PWD/config/zellij}"
    install -d "$config_dir"
    config_dir="$(cd -- "$config_dir" && pwd)"
    profile_name="$(basename "$PWD")"
    validate_name profile "$profile_name"
    root="$(resolve_root "$PWD")"
    {
      printf 'name=%s\n' "$profile_name"
      printf 'root=%s\n' "$root"
      printf 'default_workspace=%s\n' "$workspace"
      printf 'default_workspaces=%s\n' "$workspace"
    } > "$config_dir/profile.conf"
    created=true
  fi

  write_tabs_file "$config_dir" "$workspace" "${parsed_tabs[@]}"
  if [[ "$created" != "true" ]]; then
    add_profile_workspace "$config_dir/profile.conf" "$workspace"
  fi
  install_profile "$config_dir" >/dev/null
  sync_workspace_session "$config_dir" "$workspace"
  if [[ "$created" == "true" ]]; then
    printf 'Created profile and synced workspace %s.\n' "$workspace"
  else
    printf 'Synced workspace %s.\n' "$workspace"
  fi
}

create_local_workspace() {
  local workspace="$1" config_dir profile_name root created=false tabs_file
  shift

  validate_name workspace "$workspace"
  parse_tabs_args "$@"

  if ! config_dir="$(find_config_dir)"; then
    config_dir="${GOOB_CONFIG_DIR:-$PWD/config/zellij}"
    install -d "$config_dir"
    config_dir="$(cd -- "$config_dir" && pwd)"
    profile_name="$(basename "$PWD")"
    validate_name profile "$profile_name"
    root="$(resolve_root "$PWD")"
    {
      printf 'name=%s\n' "$profile_name"
      printf 'root=%s\n' "$root"
      printf 'default_workspace=%s\n' "$workspace"
      printf 'default_workspaces=%s\n' "$workspace"
    } > "$config_dir/profile.conf"
    created=true
  fi

  tabs_file="$config_dir/$workspace.tabs"
  if [[ -e "$tabs_file" ]]; then
    printf 'goob: workspace already exists: %s\n' "$workspace" >&2
    printf 'Replace it with: goob %s=<tab>,...\n' "$workspace" >&2
    exit 1
  fi

  write_tabs_file "$config_dir" "$workspace" "${parsed_tabs[@]}"
  if [[ "$created" != "true" ]]; then
    add_profile_workspace "$config_dir/profile.conf" "$workspace"
  fi
  install_profile "$config_dir" >/dev/null
  sync_workspace_session "$config_dir" "$workspace"
  if [[ "$created" == "true" ]]; then
    printf 'Created profile and workspace %s.\n' "$workspace"
  else
    printf 'Created workspace %s.\n' "$workspace"
  fi
}

replace_profile_workspace() {
  local config_file="$1" old_workspace="$2" new_workspace="$3"
  local default_workspace default_workspaces current rewritten="" emitted=" " found=false tmp

  default_workspace="$(profile_value "$config_file" default_workspace "")"
  if [[ "$default_workspace" == "$old_workspace" ]]; then
    default_workspace="$new_workspace"
  fi

  default_workspaces="$(profile_value "$config_file" default_workspaces "")"
  for current in $default_workspaces; do
    if [[ "$current" == "$old_workspace" ]]; then
      current="$new_workspace"
      found=true
    fi

    case "$emitted" in
      *" $current "*)
        continue
        ;;
    esac

    if [[ -n "$rewritten" ]]; then
      rewritten="$rewritten $current"
    else
      rewritten="$current"
    fi
    emitted="$emitted$current "
  done

  if [[ "$found" != "true" ]]; then
    if [[ -n "$rewritten" ]]; then
      rewritten="$rewritten $new_workspace"
    else
      rewritten="$new_workspace"
    fi
  fi

  tmp="$(mktemp)"
  awk -F '=' -v default_workspace="$default_workspace" -v default_workspaces="$rewritten" '
    $1 == "default_workspace" {
      print "default_workspace=" default_workspace
      wrote_default_workspace = 1
      next
    }
    $1 == "default_workspaces" {
      print "default_workspaces=" default_workspaces
      wrote_default_workspaces = 1
      next
    }
    { print }
    END {
      if (!wrote_default_workspace) print "default_workspace=" default_workspace
      if (!wrote_default_workspaces) print "default_workspaces=" default_workspaces
    }
  ' "$config_file" > "$tmp"
  cat "$tmp" > "$config_file"
  rm -f "$tmp"
}

remove_profile_workspace() {
  local config_file="$1" remove_workspace="$2"
  local default_workspace default_workspaces current rewritten="" emitted=" " found=false tmp

  default_workspace="$(profile_value "$config_file" default_workspace "")"
  default_workspaces="$(profile_value "$config_file" default_workspaces "")"

  for current in $default_workspaces; do
    if [[ "$current" == "$remove_workspace" ]]; then
      found=true
      continue
    fi

    case "$emitted" in
      *" $current "*)
        continue
        ;;
    esac

    if [[ -n "$rewritten" ]]; then
      rewritten="$rewritten $current"
    else
      rewritten="$current"
    fi
    emitted="$emitted$current "
  done

  if [[ "$found" != "true" && "$default_workspace" != "$remove_workspace" ]]; then
    return 0
  fi

  if [[ "$default_workspace" == "$remove_workspace" ]]; then
    default_workspace="${rewritten%% *}"
  fi

  tmp="$(mktemp)"
  awk -F '=' -v default_workspace="$default_workspace" -v default_workspaces="$rewritten" '
    $1 == "default_workspace" {
      print "default_workspace=" default_workspace
      wrote_default_workspace = 1
      next
    }
    $1 == "default_workspaces" {
      print "default_workspaces=" default_workspaces
      wrote_default_workspaces = 1
      next
    }
    { print }
    END {
      if (!wrote_default_workspace) print "default_workspace=" default_workspace
      if (!wrote_default_workspaces) print "default_workspaces=" default_workspaces
    }
  ' "$config_file" > "$tmp"
  cat "$tmp" > "$config_file"
  rm -f "$tmp"
}

rename_local_workspace() {
  local old_workspace="$1" new_workspace="$2" config_dir old_tabs new_tabs

  validate_name workspace "$old_workspace"
  validate_name workspace "$new_workspace"

  if config_dir="$(find_config_dir)"; then
    :
  else
    printf 'goob: could not find config/zellij; create a workspace first\n' >&2
    exit 1
  fi

  old_tabs="$config_dir/$old_workspace.tabs"
  new_tabs="$config_dir/$new_workspace.tabs"
  if [[ ! -f "$old_tabs" ]]; then
    printf 'goob: missing workspace %s in %s\n' "$old_workspace" "$config_dir" >&2
    exit 1
  fi
  if [[ -e "$new_tabs" ]]; then
    printf 'goob: workspace already exists: %s\n' "$new_workspace" >&2
    exit 1
  fi

  mv "$old_tabs" "$new_tabs"
  replace_profile_workspace "$config_dir/profile.conf" "$old_workspace" "$new_workspace"
  install_profile "$config_dir" >/dev/null
  printf 'Renamed workspace %s to %s.\n' "$old_workspace" "$new_workspace"
}

remove_local_workspace() {
  local workspace="$1" config_dir tabs_file tabs_count tabs_files=()

  validate_name workspace "$workspace"

  if config_dir="$(find_config_dir)"; then
    :
  else
    printf 'goob: could not find config/zellij; create a workspace first\n' >&2
    exit 1
  fi

  tabs_file="$config_dir/$workspace.tabs"
  if [[ ! -f "$tabs_file" ]]; then
    printf 'goob: missing workspace %s in %s\n' "$workspace" "$config_dir" >&2
    exit 1
  fi

  shopt -s nullglob
  tabs_files=("$config_dir"/*.tabs)
  shopt -u nullglob
  tabs_count="${#tabs_files[@]}"
  if (( tabs_count <= 1 )); then
    printf 'goob: cannot remove the last workspace in %s\n' "$config_dir" >&2
    exit 1
  fi

  rm -f "$tabs_file"
  remove_profile_workspace "$config_dir/profile.conf" "$workspace"
  install_profile "$config_dir" >/dev/null
  printf 'Removed workspace %s.\n' "$workspace"
}

run_install() {
  local install_script="$script_dir/../install.sh"
  if [[ ! -x "$install_script" ]]; then
    printf 'goob: install is available from the source checkout, not the installed bin directory\n' >&2
    exit 1
  fi
  exec "$install_script"
}

run_launch() {
  local workspace="$1" session="" root_override="" config_dir="" profile_name profile_dir
  shift

  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      -s | --session)
        session="${2:-}"
        shift 2
        ;;
      -r | --root)
        root_override="$(resolve_root "${2:-}")"
        shift 2
        ;;
      -h | --help)
        usage stdout
        exit 0
        ;;
      *)
        printf 'goob: unknown launch argument %s\n' "$1" >&2
        usage
        exit 2
        ;;
    esac
  done

  validate_name workspace "$workspace"
  if [[ -n "$session" ]]; then
    validate_name session "$session"
  fi

  if config_dir="$(auto_install_config)"; then
    profile_name="$(resolve_profile_name "$config_dir")"
    profile_dir="$HOME/.local/share/zellij-workspaces/profiles/$profile_name"
  else
    profile_name="$(resolve_profile_name "")"
    profile_dir="$(profile_dir_from_installed_default)"
    if [[ ! -f "$profile_dir/profile.conf" ]]; then
      printf 'goob: no local config/zellij and no installed default profile\n' >&2
      usage
      exit 1
    fi
  fi

  workspace_exists_or_exit "$profile_dir" "$workspace"
  exec "$script_dir/zwork" "$profile_name" "$workspace" "$session" "$root_override"
}

case "$command_name" in
  -h | --help | help)
    usage stdout
    exit 0
    ;;
  "")
    if config_dir="$(auto_install_config)"; then
      default_workspace="$(default_workspace_from_config "$config_dir")"
      if [[ -n "$default_workspace" ]]; then
        run_launch "$default_workspace"
      fi
    fi
    usage stdout
    exit 0
    ;;
  install)
    shift
    if [[ "$#" -gt 0 ]]; then
      printf 'goob: install does not accept arguments\n' >&2
      usage
      exit 2
    fi
    run_install
    ;;
  setup)
    shift
    config_dir="$(resolve_config_arg "$@")"
    install_profile "$config_dir"
    printf 'Installed Zellij profile %s.\n' "$(resolve_profile_name "$config_dir")"
    ;;
  doctor | check)
    shift
    if [[ "$#" -gt 0 ]]; then
      config_dir="$(resolve_config_arg "$@")"
    elif config_dir="$(auto_install_config)"; then
      :
    else
      config_dir="$(profile_dir_from_installed_default)"
    fi
    exec "$script_dir/zellij-workspace-doctor" --config "$config_dir"
    ;;
  list)
    shift
    if [[ "$#" -gt 0 ]]; then
      config_dir="$(resolve_config_arg "$@")"
    elif config_dir="$(find_config_dir)"; then
      :
    else
      config_dir="$(profile_dir_from_installed_default)"
    fi
    list_workspaces "$config_dir"
    ;;
  create)
    shift
    workspace="${1:-}"
    if [[ -z "$workspace" || "$#" -lt 2 ]]; then
      printf 'goob: create requires a workspace and at least one tab\n' >&2
      usage
      exit 2
    fi
    shift
    create_local_workspace "$workspace" "$@"
    ;;
  refresh)
    shift
    workspace="${1:-}"
    if [[ -z "$workspace" || "$#" -ne 1 ]]; then
      printf 'goob: refresh requires exactly one workspace name\n' >&2
      printf 'example: goob refresh front\n' >&2
      usage
      exit 2
    fi
    run_workspace_tab_command "$workspace" refresh
    ;;
  tab)
    shift
    action="${1:-}"
    workspace="${2:-}"
    if [[ -z "$action" || -z "$workspace" ]]; then
      printf 'goob: tab requires an action and workspace\n' >&2
      usage
      exit 2
    fi
    case "$action" in
      list | refresh)
        if [[ "$#" -ne 2 ]]; then
          printf 'goob: tab %s requires exactly one workspace\n' "$action" >&2
          usage
          exit 2
        fi
        run_workspace_tab_command "$workspace" "$action"
        ;;
      add | move | remove)
        if [[ "$#" -ne 3 ]]; then
          printf 'goob: tab %s requires a workspace and tab\n' "$action" >&2
          usage
          exit 2
        fi
        run_workspace_tab_command "$workspace" "$action" "${3:-}"
        ;;
      rename)
        if [[ "$#" -ne 4 ]]; then
          printf 'goob: tab rename requires a workspace, old tab, and new tab\n' >&2
          usage
          exit 2
        fi
        run_workspace_tab_command "$workspace" "$action" "${3:-}" "${4:-}"
        ;;
      *)
        printf 'goob: unknown tab action %s\n' "$action" >&2
        usage
        exit 2
        ;;
    esac
    ;;
  commit)
    shift
    run_commit_command "$@"
    ;;
  ps)
    shift
    if [[ "$#" -gt 0 ]]; then
      printf 'goob: ps does not accept arguments\n' >&2
      usage
      exit 2
    fi
    exec zellij list-sessions
    ;;
  kill)
    shift
    session="${1:-}"
    if [[ -z "$session" || "$#" -ne 1 ]]; then
      printf 'goob: kill requires exactly one session name\n' >&2
      usage
      exit 2
    fi
    validate_name session "$session"
    exec zellij delete-session --force "$session"
    ;;
  rename)
    shift
    if [[ "$#" -ne 2 ]]; then
      printf 'goob: rename requires old and new workspace names\n' >&2
      usage
      exit 2
    fi
    rename_local_workspace "$1" "$2"
    ;;
  remove)
    shift
    if [[ "$#" -ne 1 ]]; then
      printf 'goob: remove requires exactly one workspace name\n' >&2
      usage
      exit 2
    fi
    remove_local_workspace "$1"
    ;;
  *)
    if [[ "$command_name" == *"="* ]]; then
      if [[ "$#" -ne 1 ]]; then
        printf 'goob: workspace=tab,tab does not accept extra launch arguments\n' >&2
        usage
        exit 2
      fi
      upsert_local_workspace "$command_name"
    elif [[ "${2:-}" =~ ^(list|add|remove|move|rename|refresh)$ ]]; then
      run_workspace_tab_command "$command_name" "${@:2}"
    else
      run_launch "$command_name" "${@:2}"
    fi
    ;;
esac
