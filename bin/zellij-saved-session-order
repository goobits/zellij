#!/usr/bin/env bash
set -euo pipefail

session="${1:-}"
shift || true

if [[ -z "$session" || "$#" -eq 0 ]]; then
  printf 'usage: zellij-saved-session-order <session> <tab-name>[<tab><cwd>]...\n' >&2
  exit 2
fi

if [[ ! "$session" =~ ^[A-Za-z0-9_.-]+$ ]]; then
  printf 'zellij-saved-session-order: session names may only use letters, numbers, dot, underscore, and dash\n' >&2
  exit 2
fi

if ! command -v perl >/dev/null 2>&1; then
  exit 0
fi

layout_file="${XDG_CACHE_HOME:-$HOME/.cache}/zellij/contract_version_1/session_info/$session/session-layout.kdl"
metadata_file="${XDG_CACHE_HOME:-$HOME/.cache}/zellij/contract_version_1/session_info/$session/session-metadata.kdl"
desired_tabs=()
for tab_spec in "$@"; do
  tab_name="${tab_spec%%$'\t'*}"
  [[ -n "$tab_name" ]] || continue
  desired_tabs+=("$tab_name")
done
order="$(printf '%s\n' "${desired_tabs[@]}")"

if [[ -f "$layout_file" ]]; then
  ZELLIJ_TAB_ORDER="$order" perl -0pi -e '
    my @desired = grep { length } split /\n/, $ENV{ZELLIJ_TAB_ORDER};
    my %rank;
    for my $index (0 .. $#desired) {
      $rank{$desired[$index]} = $index;
    }

    sub base_name {
      my ($name) = @_;
      $name =~ s/ 🤖\z//;
      $name =~ s/ 🔔\z//;
      return $name;
    }

    sub quote_name {
      my ($name) = @_;
      $name =~ s/\\/\\\\/g;
      $name =~ s/"/\\"/g;
      return $name;
    }

    my @lines = split /(?<=\n)/, $_;
    my (@prefix, @blocks, @suffix);
    my $saw_tab = 0;

    for (my $index = 0; $index < @lines;) {
      if ($lines[$index] =~ /^    tab name="([^"]*)"/) {
        $saw_tab = 1;
        my $name = base_name($1);
        my @block;
        my $depth = 0;
        do {
          my $line = $lines[$index++];
          $depth += ($line =~ tr/{//);
          $depth -= ($line =~ tr/}//);
          push @block, $line;
        } while ($depth > 0 && $index < @lines);
        push @blocks, { name => $name, text => join("", @block), ordinal => scalar @blocks };
        next;
      }

      if ($saw_tab) {
        push @suffix, $lines[$index++];
      } else {
        push @prefix, $lines[$index++];
      }
    }

    my @known = sort {
      $rank{$a->{name}} <=> $rank{$b->{name}}
    } grep {
      exists $rank{$_->{name}}
    } @blocks;

    my @extra = grep {
      !exists $rank{$_->{name}}
    } @blocks;

    $_ = join("", @prefix, map({ $_->{text} } @known, @extra), @suffix);
  ' "$layout_file"
fi

if [[ -f "$metadata_file" ]]; then
  ZELLIJ_TAB_ORDER="$order" perl -0pi -e '
    my @desired = grep { length } split /\n/, $ENV{ZELLIJ_TAB_ORDER};
    my %rank;
    for my $index (0 .. $#desired) {
      $rank{$desired[$index]} = $index;
    }

    sub base_name {
      my ($name) = @_;
      $name =~ s/ 🤖\z//;
      $name =~ s/ 🔔\z//;
      return $name;
    }

    sub quote_name {
      my ($name) = @_;
      $name =~ s/\\/\\\\/g;
      $name =~ s/"/\\"/g;
      return $name;
    }

    sub reorder_blocks {
      my ($blocks) = @_;
      my @known = sort {
        $rank{$a->{name}} <=> $rank{$b->{name}}
      } grep {
        exists $rank{$_->{name}}
      } @$blocks;

      my @extra = grep {
        !exists $rank{$_->{name}}
      } @$blocks;

      return (@known, @extra);
    }

    my @lines = split /(?<=\n)/, $_;
    my (@prefix, @tabs, @between, @suffix);
    my %old_position_to_new_position;
    my $section = "prefix";

    for (my $index = 0; $index < @lines;) {
      if ($lines[$index] =~ /^tabs \{/) {
        $section = "tabs";
        push @prefix, $lines[$index++];
        next;
      }

      if ($lines[$index] =~ /^panes \{/) {
        $section = "panes";
        push @between, $lines[$index++];
        next;
      }

      if ($section eq "tabs" && $lines[$index] =~ /^    tab \{/) {
        my @block;
        my $depth = 0;
        do {
          my $line = $lines[$index++];
          $depth += ($line =~ tr/{//);
          $depth -= ($line =~ tr/}//);
          push @block, $line;
        } while ($depth > 0 && $index < @lines);

        my $text = join("", @block);
        my ($name) = $text =~ /^\s+name "([^"]*)"/m;
        my ($position) = $text =~ /^\s+position ([0-9]+)/m;
        push @tabs, {
          name => base_name($name // ""),
          old_position => $position,
          text => $text,
          ordinal => scalar @tabs,
        };
        next;
      }

      if ($section eq "prefix") {
        push @prefix, $lines[$index++];
      } elsif ($section eq "tabs") {
        push @between, $lines[$index++];
      } else {
        push @suffix, $lines[$index++];
      }
    }

    my @ordered_tabs = reorder_blocks(\@tabs);
    for my $new_position (0 .. $#ordered_tabs) {
      my $tab = $ordered_tabs[$new_position];
      $old_position_to_new_position{$tab->{old_position}} = $new_position
        if defined $tab->{old_position};
      $tab->{text} =~ s/^        position [0-9]+/        position $new_position/m;
    }

    my $suffix = join("", @suffix);
    $suffix =~ s/^        tab_position ([0-9]+)/
      exists $old_position_to_new_position{$1}
        ? "        tab_position $old_position_to_new_position{$1}"
        : $&
    /mge;

    $_ = join("", @prefix, map({ $_->{text} } @ordered_tabs), @between, $suffix);
  ' "$metadata_file"
fi
