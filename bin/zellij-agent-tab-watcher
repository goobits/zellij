#!/usr/bin/env bash
set -euo pipefail

if [[ -z "${ZELLIJ_SESSION_NAME:-}" ]]; then
  exit 0
fi

if ! command -v jq >/dev/null 2>&1; then
  exit 0
fi

watcher_name=".zellij-agent-tab-watcher"
old_watcher_name=".zellij-codex-tab-watcher"
state_dir="${XDG_RUNTIME_DIR:-/tmp}/zellij-agent-tab-watcher-${UID}-${ZELLIJ_SESSION_NAME}"
pid_file="$state_dir/watcher.pid"
status_file="$state_dir/status.tsv"
log_file="$state_dir/watcher.log"
title_log_file="$state_dir/title.log"
poll_seconds="${ZELLIJ_AGENT_TAB_WATCHER_POLL_SECONDS:-0.25}"
heartbeat_every_ticks=240
debug_titles="${ZELLIJ_AGENT_TAB_WATCHER_DEBUG_TITLES:-0}"

log_message() {
  printf '%s\t%s\n' "$(date '+%Y-%m-%dT%H:%M:%S%z')" "$*" >> "$log_file"
}

tab_base_name() {
  local tab_name
  tab_name="${1% 🤖}"
  tab_name="${tab_name% 🔔}"
  printf '%s' "$tab_name"
}

is_busy_title() {
  local pane_title="${1:-}"
  local first_char="${pane_title:0:1}"

  case "$first_char" in
    ⠋ | ⠙ | ⠹ | ⠸ | ⠼ | ⠴ | ⠦ | ⠧ | ⠇ | ⠏)
      return 0
      ;;
  esac
  [[ "$pane_title" == "✦"* ]] && return 0
  return 1
}

is_known_agent_title() {
  local pane_title="${1:-}"

  [[ "$pane_title" =~ (^|[[:space:]/])(claude|gemini|codex)([[:space:]]|$) ]]
}

is_busy_screen() {
  local pane_id="${1:-}" pane_title="${2:-}" screen

  is_known_agent_title "$pane_title" || return 1
  [[ "$pane_id" =~ ^[0-9]+$ ]] || return 1

  screen="$(zellij action dump-screen --pane-id "$pane_id" 2>/dev/null || true)"
  [[ -n "$screen" ]] || return 1

  grep -Eq '(^|[[:space:]])(· [^[:space:]].*…|✦[[:space:]]|Thinking…|Deciphering…)' <<<"$screen"
}

watcher_pids() {
  local pid

  {
    if [[ -f "$pid_file" ]]; then
      pid="$(cat "$pid_file" 2>/dev/null || true)"
      if is_watcher_pid "$pid"; then
        printf '%s\n' "$pid"
      fi
    fi

    ps -u "$USER" -o pid=,ppid=,pgid=,sid=,args= 2>/dev/null | awk -v session="$ZELLIJ_SESSION_NAME" '
      $1 == $3 && $1 == $4 {
        args = $0
        sub(/^[[:space:]]*[0-9]+[[:space:]]+[0-9]+[[:space:]]+[0-9]+[[:space:]]+[0-9]+[[:space:]]+/, "", args)
        if (args ~ "(^|[[:space:]/])\\.(zellij-agent-tab-watcher|zellij-codex-tab-watcher) --loop " session "($|[[:space:]])") {
          print $1
        }
      }
    '
  } | awk '!seen[$0]++'
}

is_watcher_pid() {
  local args pid="${1:-}"

  [[ "$pid" =~ ^[0-9]+$ ]] || return 1
  args="$(ps -p "$pid" -o args= 2>/dev/null || true)"
  [[ "$args" == *"$watcher_name --loop ${ZELLIJ_SESSION_NAME}"* || "$args" == *"$old_watcher_name --loop ${ZELLIJ_SESSION_NAME}"* ]]
}

stop_watchers() {
  local pid pids=() remaining=()

  mapfile -t pids < <(watcher_pids)
  if (( ${#pids[@]} == 0 )); then
    return 0
  fi
  log_message "stopping watcher pids=${pids[*]} session=$ZELLIJ_SESSION_NAME"
  kill "${pids[@]}" >/dev/null 2>&1 || true

  for _ in {1..20}; do
    remaining=()
    for pid in "${pids[@]}"; do
      if kill -0 "$pid" >/dev/null 2>&1; then
        remaining+=("$pid")
      fi
    done
    if (( ${#remaining[@]} == 0 )); then
      return 0
    fi
    sleep 0.05
  done
}

rename_tabs_to_base_names() {
  local tab_state tab_id tab_name base_name

  tab_state="$(zellij action list-tabs --json 2>/dev/null || true)"
  [[ -n "$tab_state" ]] || return 0

  while IFS=$'\t' read -r tab_id tab_name; do
    [[ -z "$tab_id" || -z "$tab_name" ]] && continue
    base_name="$(tab_base_name "$tab_name")"
    if [[ "$tab_name" != "$base_name" ]]; then
      zellij action rename-tab-by-id "$tab_id" "$base_name" >/dev/null 2>&1 || true
    fi
  done < <(
    jq -r '
      .[]
      | [.tab_id, .name]
      | @tsv
    ' <<<"$tab_state" 2>/dev/null || true
  )
}

reset_state() {
  mkdir -p "$state_dir"
  rename_tabs_to_base_names
  rm -f "$status_file" "$state_dir"/busy-*.txt "$state_dir"/notify-*.txt "$state_dir"/tab-busy-*.txt "$state_dir"/title-*.txt
  log_message "reset watcher state for $ZELLIJ_SESSION_NAME"
}

start_watcher() {
  local pids=() watcher_pid

  mkdir -p "$state_dir"
  mapfile -t pids < <(watcher_pids)
  if (( ${#pids[@]} > 1 )); then
    log_message "stopping duplicate watcher pids=${pids[*]:1} session=$ZELLIJ_SESSION_NAME"
    kill "${pids[@]:1}" >/dev/null 2>&1 || true
  fi
  if (( ${#pids[@]} > 0 )); then
    exit 0
  fi
  log_message "starting watcher for $ZELLIJ_SESSION_NAME"
  if command -v setsid >/dev/null 2>&1; then
    nohup setsid env ZELLIJ_SESSION_NAME="$ZELLIJ_SESSION_NAME" "$0" --loop "$ZELLIJ_SESSION_NAME" </dev/null >>"$log_file" 2>&1 &
  else
    nohup env ZELLIJ_SESSION_NAME="$ZELLIJ_SESSION_NAME" "$0" --loop "$ZELLIJ_SESSION_NAME" </dev/null >>"$log_file" 2>&1 &
  fi
  watcher_pid=$!
  printf '%s' "$watcher_pid" > "$pid_file"
}

remove_pid_file() {
  if [[ "$(cat "$pid_file" 2>/dev/null || true)" == "$$" ]]; then
    rm -f "$pid_file"
  fi
}

run_once() {
  local pane_state tab_state terminal_panes run_tmp busy_tabs notifying_tabs status_next pane_title now is_busy previous_title previous_busy
  local tab_id tab_name tab_active base_name next_name current_tab_busy previous_tab_busy notify_file

  mkdir -p "$state_dir"
  run_tmp="$(mktemp -d)"
  trap 'rm -rf "$run_tmp"' RETURN

  pane_state="$(zellij action list-panes --all --json 2>/dev/null || true)"
  if [[ -z "$pane_state" ]]; then
    rm -rf "$run_tmp"
    trap - RETURN
    return 0
  fi
  tab_state="$(zellij action list-tabs --json 2>/dev/null || true)"
  terminal_panes="$(jq -r '
    .[]
    | select(.is_plugin == false)
    | [.id, .tab_id, .tab_name, (.title // "")]
    | @tsv
  ' <<<"$pane_state" 2>/dev/null || true)"

  busy_tabs="$run_tmp/busy-tabs"
  notifying_tabs="$run_tmp/notifying-tabs"
  status_next="$run_tmp/status-next"
  : > "$busy_tabs"
  : > "$notifying_tabs"
  : > "$status_next"
  now="$(date '+%Y-%m-%dT%H:%M:%S%z')"

  while IFS=$'\t' read -r pane_id tab_id tab_name pane_title; do
    [[ -z "$pane_id" || -z "$tab_id" || -z "$tab_name" ]] && continue

    previous_title=""
    if [[ -f "$state_dir/title-${pane_id}.txt" ]]; then
      previous_title="$(cat "$state_dir/title-${pane_id}.txt")"
    fi
    if [[ "$debug_titles" == "1" && "$pane_title" != "$previous_title" ]]; then
      printf '%s\tpane=%s\ttab=%s\tname=%s\ttitle=%s\n' "$now" "$pane_id" "$tab_id" "$(tab_base_name "$tab_name")" "$pane_title" >> "$title_log_file"
    fi
    if [[ "$pane_title" != "$previous_title" ]]; then
      printf '%s' "$pane_title" > "$state_dir/title-${pane_id}.txt"
    fi

    is_busy=false
    if is_busy_title "$pane_title" || is_busy_screen "$pane_id" "$pane_title"; then
      is_busy=true
      printf '%s\n' "$tab_id" >> "$busy_tabs"
    fi

    previous_busy=""
    if [[ -f "$state_dir/busy-${pane_id}.txt" ]]; then
      previous_busy="$(cat "$state_dir/busy-${pane_id}.txt")"
    fi
    if [[ "$is_busy" != "$previous_busy" ]]; then
      printf '%s\tpane=%s\ttab=%s\tname=%s\tbusy=%s\ttitle=%s\n' "$now" "$pane_id" "$tab_id" "$(tab_base_name "$tab_name")" "$is_busy" "$pane_title" >> "$title_log_file"
      printf '%s' "$is_busy" > "$state_dir/busy-${pane_id}.txt"
    fi
  done <<<"$terminal_panes"

  sort -u "$busy_tabs" -o "$busy_tabs"

  while IFS=$'\t' read -r tab_id tab_name tab_active; do
    [[ -z "$tab_id" || -z "$tab_name" ]] && continue

    current_tab_busy=false
    if grep -Fx "$tab_id" "$busy_tabs" >/dev/null 2>&1; then
      current_tab_busy=true
    fi

    previous_tab_busy=false
    if [[ -f "$state_dir/tab-busy-${tab_id}.txt" ]]; then
      previous_tab_busy="$(cat "$state_dir/tab-busy-${tab_id}.txt")"
    fi

    notify_file="$state_dir/notify-${tab_id}.txt"
    if [[ "$current_tab_busy" == "true" ]]; then
      rm -f "$notify_file"
    elif [[ "$tab_active" == "true" ]]; then
      rm -f "$notify_file"
    elif [[ "$previous_tab_busy" == "true" ]]; then
      printf 'true' > "$notify_file"
    fi

    printf '%s' "$current_tab_busy" > "$state_dir/tab-busy-${tab_id}.txt"

    if [[ -f "$notify_file" ]]; then
      printf '%s\n' "$tab_id" >> "$notifying_tabs"
    fi
  done < <(
    jq -r '
      .[]
      | [.tab_id, .name, .active]
      | @tsv
    ' <<<"$tab_state" 2>/dev/null || true
  )

  sort -u "$notifying_tabs" -o "$notifying_tabs"

  while IFS=$'\t' read -r pane_id tab_id tab_name pane_title; do
    [[ -z "$pane_id" || -z "$tab_id" || -z "$tab_name" ]] && continue

    is_busy=false
    if grep -Fx "$tab_id" "$busy_tabs" >/dev/null 2>&1; then
      is_busy=true
    fi

    is_notifying=false
    if grep -Fx "$tab_id" "$notifying_tabs" >/dev/null 2>&1; then
      is_notifying=true
    fi

    printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$pane_id" "$tab_id" "$tab_name" "$pane_title" "$is_busy" "$is_notifying" >> "$status_next"
  done <<<"$terminal_panes"

  while IFS=$'\t' read -r tab_id tab_name; do
    [[ -z "$tab_id" || -z "$tab_name" ]] && continue

    base_name="$(tab_base_name "$tab_name")"
    next_name="$base_name"

    if grep -Fx "$tab_id" "$busy_tabs" >/dev/null 2>&1; then
      next_name="$base_name 🤖"
    elif grep -Fx "$tab_id" "$notifying_tabs" >/dev/null 2>&1; then
      next_name="$base_name 🔔"
    fi

    if [[ "$tab_name" != "$next_name" ]]; then
      zellij action rename-tab-by-id "$tab_id" "$next_name" >/dev/null 2>&1 || true
    fi
  done < <(
    jq -r '
      .[]
      | [.tab_id, .name]
      | @tsv
    ' <<<"$tab_state" 2>/dev/null || true
  )

  mv "$status_next" "$status_file"
  rm -rf "$run_tmp"
  trap - RETURN
}

case "${1:-}" in
  --once)
    run_once
    ;;
  --start)
    start_watcher
    ;;
  --reset)
    reset_state
    ;;
  --stop)
    stop_watchers
    ;;
  --restart)
    stop_watchers
    start_watcher
    ;;
  --status)
    if [[ ! -f "$status_file" ]]; then
      printf 'No watcher status yet for session %s.\n' "$ZELLIJ_SESSION_NAME" >&2
      exit 1
    fi
    printf 'PANE\tTAB\tNAME\tTITLE\tBUSY\tNOTIFY\n'
    cat "$status_file"
    ;;
  --log)
    if [[ ! -f "$title_log_file" ]]; then
      printf 'No title log yet for session %s.\n' "$ZELLIJ_SESSION_NAME" >&2
      exit 1
    fi
    tail -n "${2:-40}" "$title_log_file"
    ;;
  --watcher-log)
    if [[ ! -f "$log_file" ]]; then
      printf 'No watcher log yet for session %s.\n' "$ZELLIJ_SESSION_NAME" >&2
      exit 1
    fi
    tail -n "${2:-40}" "$log_file"
    ;;
  --loop)
    requested_session="${2:-}"
    [[ "$requested_session" == "$ZELLIJ_SESSION_NAME" ]] || exit 0
    printf '%s' "$$" > "$pid_file"
    log_message "watcher loop started pid=$$ session=$ZELLIJ_SESSION_NAME"
    trap 'status=$?; remove_pid_file; log_message "watcher loop exited pid=$$ status=$status"; exit "$status"' EXIT
    trap 'log_message "watcher loop got SIGHUP pid=$$"' HUP
    trap 'log_message "watcher loop got SIGTERM pid=$$"; exit 143' TERM
    trap 'log_message "watcher loop got SIGINT pid=$$"; exit 130' INT
    tick=0
    while :; do
      if ! run_once; then
        log_message "run_once failed pid=$$"
      fi
      tick=$((tick + 1))
      if (( tick % heartbeat_every_ticks == 0 )); then
        log_message "heartbeat pid=$$ session=$ZELLIJ_SESSION_NAME"
      fi
      sleep "$poll_seconds"
    done
    ;;
  *)
    run_once
    ;;
esac
