#!/usr/bin/env bash
set -euo pipefail

profile="${1:-}"
workspace="${2:-}"
session="${3:-}"
workdir="${4:-}"

if [[ -z "$profile" || -z "$workspace" ]]; then
  printf 'usage: zwork <profile> <workspace> [session] [workdir]\n' >&2
  exit 2
fi

if [[ "$profile" != */* && ! "$profile" =~ ^[A-Za-z0-9_.-]+$ ]]; then
  printf 'zwork: profile names may only use letters, numbers, dot, underscore, and dash\n' >&2
  exit 2
fi

if [[ ! "$workspace" =~ ^[A-Za-z0-9_.-]+$ ]]; then
  printf 'zwork: workspace names may only use letters, numbers, dot, underscore, and dash\n' >&2
  exit 2
fi

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

resolve_profile_dir() {
  local candidate profile_name="$1"
  if [[ -d "$profile_name" ]]; then
    cd "$profile_name"
    pwd
    return
  fi

  if [[ -n "${ZELLIJ_PROFILE_DIR:-}" ]]; then
    candidate="$ZELLIJ_PROFILE_DIR/$profile_name"
    if [[ -d "$candidate" ]]; then
      cd "$candidate"
      pwd
      return
    fi
  fi

  for candidate in \
    "$script_dir/../profiles/$profile_name" \
    "$HOME/.local/share/zellij-workspaces/profiles/$profile_name"
  do
    [[ -n "$candidate" && -d "$candidate" ]] || continue
    cd "$candidate"
    pwd
    return
  done

  printf 'zwork: missing profile %s\n' "$profile_name" >&2
  exit 1
}

profile_value() {
  local config_file="$1" key="$2" default_value="${3:-}"
  if [[ ! -f "$config_file" ]]; then
    printf '%s' "$default_value"
    return
  fi

  awk -F '=' -v key="$key" -v default_value="$default_value" '
    $1 == key {
      value = substr($0, length(key) + 2)
      gsub(/\r$/, "", value)
      print value
      found = 1
      exit
    }
    END {
      if (!found) print default_value
    }
  ' "$config_file"
}

profile_dir="$(resolve_profile_dir "$profile")"
config_file="$profile_dir/profile.conf"
root="$(profile_value "$config_file" root /workspace)"
session="${session:-$workspace}"
workdir="${workdir:-${ZELLIJ_WORKDIR:-$root}}"

exec "$script_dir/zellij-open-session" "$profile_dir" "$workspace" "$session" "$workdir"
