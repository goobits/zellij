#!/usr/bin/env bash
set -euo pipefail

config_dir=""
failures=0

usage() {
  printf 'usage: zellij-workspace-doctor [--config <profile-dir>]\n' >&2
}

while [[ "$#" -gt 0 ]]; do
  case "$1" in
    --config)
      config_dir="${2:-}"
      shift 2
      ;;
    -h | --help)
      usage
      exit 0
      ;;
    *)
      printf 'zellij-workspace-doctor: unknown argument %s\n' "$1" >&2
      usage
      exit 2
      ;;
  esac
done

check_file() {
  local path="$1"
  if [[ -f "$path" ]]; then
    printf 'ok: %s\n' "$path"
    return
  fi

  printf 'missing: %s\n' "$path" >&2
  failures=$((failures + 1))
}

check_executable() {
  local path="$1"
  if [[ -x "$path" ]]; then
    printf 'ok: %s\n' "$path"
    return
  fi

  printf 'missing executable: %s\n' "$path" >&2
  failures=$((failures + 1))
}

profile_value() {
  local config_file="$1" key="$2" default_value="${3:-}"
  awk -F '=' -v key="$key" -v default_value="$default_value" '
    $1 == key {
      value = substr($0, length(key) + 2)
      gsub(/\r$/, "", value)
      print value
      found = 1
      exit
    }
    END {
      if (!found) print default_value
    }
  ' "$config_file"
}

if command -v zellij >/dev/null 2>&1; then
  printf 'ok: zellij %s\n' "$(zellij --version 2>/dev/null || printf 'installed')"
else
  printf 'missing: zellij command\n' >&2
  failures=$((failures + 1))
fi

check_file "$HOME/.config/zellij/config.kdl"

if command -v zellij >/dev/null 2>&1 && [[ -f "$HOME/.config/zellij/config.kdl" ]]; then
  if zellij setup --check >/dev/null 2>&1; then
    printf 'ok: zellij config is valid\n'
  else
    printf 'invalid: zellij config check failed\n' >&2
    failures=$((failures + 1))
  fi
fi

for executable in \
  zwork \
  zellij-launch-session \
  zellij-open-session \
  zellij-render-layout \
  zellij-saved-session-order \
  zellij-live-tab-order \
  zellij-session-tab-order \
  zellij-new-scratch-tab \
  goob \
  zellij-workspace-init \
  zellij-workspace-doctor \
  .zellij-agent-tab-watcher
do
  check_executable "$HOME/.local/bin/$executable"
done

if [[ -n "$config_dir" ]]; then
  if [[ ! -d "$config_dir" ]]; then
    printf 'missing profile config directory: %s\n' "$config_dir" >&2
    failures=$((failures + 1))
  else
    config_dir="$(cd -- "$config_dir" && pwd)"
    profile_name="$(profile_value "$config_dir/profile.conf" name "$(basename "$config_dir")")"
    profile_target="$HOME/.local/share/zellij-workspaces/profiles/$profile_name"

    check_file "$config_dir/profile.conf"
    check_file "$profile_target/profile.conf"

    shopt -s nullglob
    tabs_files=("$config_dir"/*.tabs)
    shopt -u nullglob

    if (( ${#tabs_files[@]} == 0 )); then
      printf 'missing: %s/*.tabs\n' "$config_dir" >&2
      failures=$((failures + 1))
    fi

    checked_workspaces=""
    check_workspace_tabs() {
      local workspace="$1"
      [[ -n "$workspace" ]] || return
      case " $checked_workspaces " in
        *" $workspace "*)
          return
          ;;
      esac
      checked_workspaces="$checked_workspaces $workspace"
      check_file "$profile_target/$workspace.tabs"
    }

    for tabs_file in "${tabs_files[@]}"; do
      check_workspace_tabs "$(basename "$tabs_file" .tabs)"
    done

    default_workspace="$(profile_value "$config_dir/profile.conf" default_workspace "")"
    check_workspace_tabs "$default_workspace"

    default_workspaces="$(profile_value "$config_dir/profile.conf" default_workspaces "")"
    for workspace in $default_workspaces; do
      check_workspace_tabs "$workspace"
    done

    if [[ -d "$config_dir/bin" ]]; then
      shopt -s nullglob
      launcher_files=("$config_dir"/bin/*)
      shopt -u nullglob

      for launcher_file in "${launcher_files[@]}"; do
        [[ -f "$launcher_file" && -x "$launcher_file" ]] || continue
        check_executable "$HOME/.local/bin/$(basename "$launcher_file")"
      done
    fi
  fi
fi

if (( failures > 0 )); then
  printf 'zellij-workspace-doctor: %s check(s) failed\n' "$failures" >&2
  exit 1
fi

printf 'zellij-workspace-doctor: all checks passed\n'
