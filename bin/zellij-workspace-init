#!/usr/bin/env bash
set -euo pipefail

config_dir=""

usage() {
  printf 'usage: zellij-workspace-init --config <profile-dir>\n' >&2
}

while [[ "$#" -gt 0 ]]; do
  case "$1" in
    --config)
      config_dir="${2:-}"
      shift 2
      ;;
    -h | --help)
      usage
      exit 0
      ;;
    *)
      printf 'zellij-workspace-init: unknown argument %s\n' "$1" >&2
      usage
      exit 2
      ;;
  esac
done

if [[ -z "$config_dir" ]]; then
  usage
  exit 2
fi

if [[ ! -d "$config_dir" ]]; then
  printf 'zellij-workspace-init: missing profile directory %s\n' "$config_dir" >&2
  exit 1
fi

config_dir="$(cd -- "$config_dir" && pwd)"
profile_name="$(basename "$config_dir")"

if [[ ! "$profile_name" =~ ^[A-Za-z0-9_.-]+$ ]]; then
  printf 'zellij-workspace-init: profile directory name may only use letters, numbers, dot, underscore, and dash\n' >&2
  exit 1
fi

if [[ ! -f "$config_dir/profile.conf" ]]; then
  printf 'zellij-workspace-init: missing %s/profile.conf\n' "$config_dir" >&2
  exit 1
fi

profile_value() {
  local config_file="$1" key="$2" default_value="${3:-}"
  awk -F '=' -v key="$key" -v default_value="$default_value" '
    $1 == key {
      value = substr($0, length(key) + 2)
      gsub(/\r$/, "", value)
      print value
      found = 1
      exit
    }
    END {
      if (!found) print default_value
    }
  ' "$config_file"
}

profile_name="$(profile_value "$config_dir/profile.conf" name "$profile_name")"
default_workspace="$(profile_value "$config_dir/profile.conf" default_workspace "")"

if [[ ! "$profile_name" =~ ^[A-Za-z0-9_.-]+$ ]]; then
  printf 'zellij-workspace-init: profile name may only use letters, numbers, dot, underscore, and dash\n' >&2
  exit 1
fi

shopt -s nullglob
tabs_files=("$config_dir"/*.tabs)
shopt -u nullglob

if (( ${#tabs_files[@]} == 0 )); then
  printf 'zellij-workspace-init: expected at least one *.tabs file in %s\n' "$config_dir" >&2
  exit 1
fi

profile_target="$HOME/.local/share/zellij-workspaces/profiles/$profile_name"
state_dir="$HOME/.local/share/zellij-workspaces"

rm -rf "$profile_target"
install -d "$profile_target" "$state_dir" "$HOME/.local/bin"
install -m 0644 "$config_dir/profile.conf" "$profile_target/profile.conf"
printf '%s\n' "$profile_name" > "$state_dir/default-profile"

for tabs_file in "${tabs_files[@]}"; do
  install -m 0644 "$tabs_file" "$profile_target/$(basename "$tabs_file")"
done

if [[ -d "$config_dir/bin" ]]; then
  shopt -s nullglob
  launcher_files=("$config_dir"/bin/*)
  shopt -u nullglob

  for launcher_file in "${launcher_files[@]}"; do
    [[ -f "$launcher_file" && -x "$launcher_file" ]] || continue
    install -m 0755 "$launcher_file" "$HOME/.local/bin/$(basename "$launcher_file")"
  done
fi

printf 'Installed Zellij profile %s.\n' "$profile_name"
if [[ -n "$default_workspace" ]]; then
  printf 'Run: goob %s\n' "$default_workspace"
else
  printf 'Run: goob <workspace>\n'
fi
