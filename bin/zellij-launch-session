#!/usr/bin/env bash
set -euo pipefail

layout_file="${1:-}"
session="${2:-}"
workdir="${3:-}"
shift 3 || true

if [[ -z "$layout_file" || -z "$session" || -z "$workdir" || "$#" -eq 0 ]]; then
  printf 'usage: zellij-launch-session <layout-file> <session> <workdir> <tab-name>...\n' >&2
  exit 2
fi

if [[ ! "$session" =~ ^[A-Za-z0-9_.-]+$ ]]; then
  printf 'zellij-launch-session: session names may only use letters, numbers, dot, underscore, and dash\n' >&2
  exit 2
fi

if [[ ! -f "$layout_file" ]]; then
  printf 'zellij-launch-session: missing layout file %s\n' "$layout_file" >&2
  exit 1
fi

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
tab_order_helper="$script_dir/zellij-session-tab-order"

repair_saved_session_shells() {
  local user_shell="${SHELL:-}" broken_shell="${ZELLIJ_REPAIR_BROKEN_SHELL:-/usr/bin/zsh}"
  local session_dir file

  [[ -n "$user_shell" && -x "$user_shell" ]] || return 0
  [[ -n "$broken_shell" && "$broken_shell" != "$user_shell" ]] || return 0
  [[ ! -x "$broken_shell" ]] || return 0
  command -v perl >/dev/null 2>&1 || return 0

  session_dir="${XDG_CACHE_HOME:-$HOME/.cache}/zellij/contract_version_1/session_info/$session"
  for file in "$session_dir/session-layout.kdl" "$session_dir/session-metadata.kdl"; do
    [[ -f "$file" ]] || continue
    ZELLIJ_BROKEN_SHELL="$broken_shell" ZELLIJ_USER_SHELL="$user_shell" perl -0pi -e '
      s/\Q$ENV{ZELLIJ_BROKEN_SHELL}\E/$ENV{ZELLIJ_USER_SHELL}/g
    ' "$file"
  done
}

if [[ -d "$workdir" ]]; then
  cd "$workdir"
fi

repair_saved_session_shells

if [[ -x "$tab_order_helper" ]]; then
  ZELLIJ_SESSION_TAB_DEFAULT_CWD="$workdir" ZELLIJ_SESSION_TAB_ORDER_CREATE_MISSING=1 "$tab_order_helper" "$session" "$@"
fi

if [[ -x "$HOME/.local/bin/.zellij-agent-tab-watcher" ]]; then
  ZELLIJ=1 ZELLIJ_SESSION_NAME="$session" "$HOME/.local/bin/.zellij-agent-tab-watcher" --start
fi

if [[ -n "${ZELLIJ:-}" ]]; then
  exec zellij action switch-session --layout "$layout_file" --cwd "$workdir" "$session"
fi

if zellij list-sessions --short --no-formatting 2>/dev/null | grep -Fx "$session" >/dev/null; then
  exec zellij attach --force-run-commands "$session"
fi

exec zellij --layout "$layout_file" attach --force-run-commands "$session" --create
